{% query pages from page.pages %}
  {
    "where": {
      "template_name_eq": "page"
    },
    "order_by": "-published_at"
  }
{% endquery %}

<main class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-4">
    {% render 'breadcrumb', breadcrumb: page.breadcrumb %}
  </div>
  <div class="md:flex md:space-x-6">

    <div class="md:w-1/4 mb-6 md:mb-0">
      <div class="glass-card p-6 rounded-2xl sticky top-20">

        <h2 class="text-xl font-bold text-gray-900 mb-5">{{ page.link_text }}</h2>
        <div class="relative mb-5 text-sm text-gray-500 line-clamp-4">
          {{ page.settings.description }}
        </div>

        <div class="relative mb-5">
          {% render 'search_block' %}
        </div>

        <nav class="space-y-1">

          <a href="{{ page.path }}" class="flex items-center justify-start px-4 py-3 space-x-2 bg-primary text-white rounded-lg font-semibold transition duration-150">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="size-5 h-5 w-5">
              <path d="M5.566 4.657A4.505 4.505 0 0 1 6.75 4.5h10.5c.41 0 .806.055 1.183.157A3 3 0 0 0 15.75 3h-7.5a3 3 0 0 0-2.684 1.657ZM2.25 12a3 3 0 0 1 3-3h13.5a3 3 0 0 1 3 3v6a3 3 0 0 1-3 3H5.25a3 3 0 0 1-3-3v-6ZM5.25 7.5c-.41 0-.806.055-1.184.157A3 3 0 0 1 6.75 6h10.5a3 3 0 0 1 2.683 1.657A4.505 4.505 0 0 0 18.75 7.5H5.25Z" />
            </svg>
            <span>{{ 'templates.channel.show_all' | t }}</span>
          </a>
          {% for item in page.children_in_list %}
            {% if item.template_name == 'channel' %}
              <div x-data="{ open: false }" class="group">
                <a
                  @click.prevent="open = !open"
                  href="{{ item.path }}"
                  class="flex items-center justify-between px-4 py-3 text-gray-700 hover:bg-gray-100 rounded-lg transition duration-150 cursor-pointer">
                  <span class="flex items-center space-x-2">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="currentColor"
                      class="size-5 h-5 w-5">
                      <path d="M19.906 9c.382 0 .749.057 1.094.162V9a3 3 0 0 0-3-3h-3.879a.75.75 0 0 1-.53-.22L11.47 3.66A2.25 2.25 0 0 0 9.879 3H6a3 3 0 0 0-3 3v3.162A3.756 3.756 0 0 1 4.094 9h15.812ZM4.094 10.5a2.25 2.25 0 0 0-2.227 2.568l.857 6A2.25 2.25 0 0 0 4.951 21H19.05a2.25 2.25 0 0 0 2.227-1.932l.857-6a2.25 2.25 0 0 0-2.227-2.568H4.094Z" />
                    </svg>
                    <span>{{ item.link_text }}</span>
                  </span>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    class="size-5 h-5 w-5 text-xs text-gray-400 transform transition-transform duration-200"
                    :class="{ 'rotate-180': open }">
                    <path
                      fill-rule="evenodd"
                      d="M12.53 16.28a.75.75 0 0 1-1.06 0l-7.5-7.5a.75.75 0 0 1 1.06-1.06L12 14.69l6.97-6.97a.75.75 0 1 1 1.06 1.06l-7.5 7.5Z"
                      clip-rule="evenodd" />
                  </svg>
                </a>
                <div
                  x-show="open"
                  x-transition:enter="transition ease-out duration-200"
                  x-transition:enter-start="opacity-0 transform -translate-y-2"
                  x-transition:enter-end="opacity-100 transform translate-y-0"
                  x-transition:leave="transition ease-in duration-150"
                  x-transition:leave-start="opacity-100 transform translate-y-0"
                  x-transition:leave-end="opacity-0 transform -translate-y-2"
                  class="ml-6 pt-1 space-y-1 text-sm text-gray-600">
                  {% for item2 in item.children_in_list | limit: 8 %}
                    <a href="{{ item2.path }}" class="block px-3 py-2 hover:text-indigo-600 rounded-md">{{ item2.link_text }}</a>
                  {% endfor %}
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </nav>
      </div>
    </div>

    <div class="md:w-3/4">
      {% paginate_tag pages, per: 32 %}
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {% for item in pages %}
            {% render 'section/page_card', page: item %}
          {% endfor %}
        </div>

        <div class="flex justify-center mt-8">
          {% render 'paginate', paginate: paginate %}
        </div>
      {% endpaginate_tag %}
    </div>
  </div>
</main>

{% schema %}
  {
    "name": "t:schema.templates.channel.name",
    "description": "t:schema.templates.channel.description",
    "thumb_url": "images/schema/channel.webp",
    "preview_image_urls": ["images/schema/channel.webp"],
    "sub_page_templates": ["channel", "page"],
    "settings": [
      {
        "id": "title",
        "type": "text",
        "label": "t:schema.templates.page.settings.title.label"
      },
      {
        "id": "description",
        "type": "textarea",
        "label": "t:schema.templates.page.settings.description.label"
      },
      {
        "id": "content",
        "type": "richtext",
        "label": "t:schema.templates.page.settings.content.label",
        "readonly": false,
        "info": "t:schema.templates.page.settings.content.info"
      }
    ]
  }
{% endschema %}