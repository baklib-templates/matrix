{% assign home_html = page.settings.home_html | present %}

<main class="min-h-full">
  {% if home_html %}
    {{ home_html }}
  {% else %}
    <!-- Hero -->
    <section class="relative">
      <!-- Dark background -->
      <div
        class="absolute inset-0 bg-[var(--header-bg)] pointer-events-none -z-10 [clip-path:polygon(0_0,_5760px_0,_5760px_calc(100%_-_352px),_0_100%)]"
        aria-hidden="true">
      </div>

      <div class="relative container mx-auto px-4 sm:px-6">
        <div class="pt-32 pb-20 md:pt-40 md:pb-44">

          <!-- Hero content -->
          <div
            class="max-w-xl mx-auto md:max-w-none md:flex md:items-center md:space-x-8 lg:space-x-16 xl:space-x-20 space-y-16 md:space-y-0">

            <!-- Content -->
            <div class="text-left md:min-w-[30rem]" data-aos="fade-right">
              <h1 class="text-3xl md:text-5xl font-bold text-slate-100 mb-4">{{ 'templates.index_preview.hero_title' | t }}</h1>
              <p class="text-md md:text-xl text-white mb-2">{{ 'templates.index_preview.hero_lead' | t }}</p>
              <p class="text-md md:text-lg text-slate-400">{{ 'templates.index_preview.hero_bullet_1' | t }}</p>
              <p class="text-md md:text-lg text-slate-400">{{ 'templates.index_preview.hero_bullet_2' | t }}</p>
              <p class="text-md md:text-lg text-slate-400 mb-8">{{ 'templates.index_preview.hero_bullet_3' | t }}</p>
              <div
                class="max-w-xs mx-auto sm:max-w-none sm:flex sm:justify-center md:justify-start space-y-4 sm:space-y-0 sm:space-x-4">
                <div>
                  <a class="btn btn-lg font-normal shadow-none border-0 text-white bg-blue-600 hover:bg-blue-800 w-full group"
                    href="https://www.baklib.cn/about/contact" target="_blank">
                    {{ 'templates.index_preview.contact_cta' | t }}<span
                      class="tracking-normal text-blue-300 group-hover:translate-x-0.5 transition-transform duration-150 ease-in-out ml-1">-&gt;</span>
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

