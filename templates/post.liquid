
{% if page.settings.content_type.value == '1' %}
  {% layout 'simple' %}
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 pt-8 pb-2">
    {% render 'breadcrumb', breadcrumb: page.breadcrumb %}
  </div>
  {{ page.settings.html_content }}
{% else %}
  {% assign pages = page.children_in_list %}
  {% assign parent = page.parent %}
  {% assign parent_pages = parent.children_in_list | order_by: '-created_at' | limit: 12 %}

  <main class="container mx-auto px-4 sm:px-6 lg:px-8 py-8 ">
    <div class="mb-4">
      {% render 'breadcrumb', breadcrumb: page.breadcrumb %}
    </div>
    <div class="md:flex md:space-x-6">

      <div class="md:w-1/4 mb-6 md:mb-0">
        <div class="glass-card p-6 rounded-2xl sticky top-20">
          <h2 class="text-xl font-bold text-gray-900 mb-2">{{ parent.link_text }}</h2>
          <div class="flex space-x-2 mb-2">
            {% if page.settings.original_url %}
              <a href="{{ page.settings.original_url }}" target="_blank" class="flex-none p-1 bg-gray-100 rounded-lg border border-gray-150 hover:bg-primary">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5 h-5 w-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                </svg>
              </a>
            {% endif %}
          </div>
      
          <div class="relative mb-5 text-sm text-gray-500">
            {{ parent.settings.description }}
          </div>
          <nav class="space-y-1">
            <hr class="text-gray-300 mb-4"/>
            {% for item in parent_pages %}
              <a
                href="{{ item.path }}"
                class="{% if item.path == page.path %} bg-primary text-white {% endif %} flex items-center justify-between py-2 text-gray-700 hover:bg-secondary rounded-lg transition duration-150 cursor-pointer">
                <span class="flex items-center space-x-2 ml-2">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5 w-5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                  </svg>
                  <span>{{ item.link_text }}</span>
                </span>
              </a>
            {% endfor %}
              
          </nav>
        </div>
      </div>

      <div class="md:w-3/4 glass-card p-6 rounded-2xl">
        {% render 'page', page: page %}
      </div>
    </div>
  </main>
{% endif %}

{% schema %}
  {
    "name": "t:schema.templates.post_detail.name",
    "description": "t:schema.templates.post_detail.description",
    "thumb_url": "images/schema/post.webp",
    "preview_image_urls": [
      "images/schema/post.webp"
    ],
    "sub_page_templates": [],
    "settings": [
			{
        "id": "title",
        "type": "text",
        "label": "t:schema.templates.page.settings.title.label"
      },
			{
        "id": "description",
        "type": "textarea",
        "label": "t:schema.templates.page.settings.description.label"
      },
      {
        "id": "tags",
        "type": "tag_picker",
        "multiple": true,
        "label": "t:schema.templates.post_detail.settings.tags.label"
      },
      {
        "id": "content_type",
        "type": "radio",
        "label": "t:schema.templates.product_index.settings.content_type.label",
        "choices": [
          {"label": "t:schema.templates.post_detail.settings.content_type.choice_richtext", "value": "0"},
          {"label": "t:schema.templates.post_detail.settings.content_type.choice_html", "value": "1"}
        ],
        "default": "0",
        "info": "t:schema.templates.product_index.settings.content_type.info "
      },
			{
        "id": "html_content",
        "type": "html",
        "label": "t:schema.templates.post_detail.settings.html_content.label"
      },
			{
				"id": "content",
				"type": "richtext",
				"label": "t:schema.templates.page.settings.content.label",
				"readonly": false,
				"info": "t:schema.templates.page.settings.content.info"
			}
    ]
  }
{% endschema %}
