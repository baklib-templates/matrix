{% assign channels = page.children_in_list %}
{% query pages from site.pages %}
  {
    "where": {
      "template_name_eq": "page"
    },
    "order_by": "-published_at"
  }
{% endquery %}


{% if page.settings.hero_html %}
  <section id="hero" class="">
    {{ page.settings.hero_html }}
  </section>
{% else %}
  {% render 'hero' %}
{% endif %}

<main class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Featured Section -->
  {% render 'section/recommended_products' %} 

  <div class="md:flex md:space-x-6">

      <div class="md:w-1/4 min-w-64 mb-6 md:mb-0">
          <div class="glass-card p-6 rounded-2xl sticky top-16 z-50">

              <h2 class="text-xl font-bold text-gray-900 mb-5">{{ 'templates.index.category_nav' | t }}</h2>

              <div class="relative mb-5">
                  {% render 'search_block' %}
              </div>

              <nav class="space-y-1" x-data="{ listExpanded: true }">
                <div class="flex items-center space-x-1">
                  <a href="{{ site.index_path }}" class="flex-1 flex items-center justify-start px-4 py-3 space-x-2 bg-primary text-white rounded-lg font-semibold transition duration-150">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-5 h-5 w-5">
                        <path d="M5.566 4.657A4.505 4.505 0 0 1 6.75 4.5h10.5c.41 0 .806.055 1.183.157A3 3 0 0 0 15.75 3h-7.5a3 3 0 0 0-2.684 1.657ZM2.25 12a3 3 0 0 1 3-3h13.5a3 3 0 0 1 3 3v6a3 3 0 0 1-3 3H5.25a3 3 0 0 1-3-3v-6ZM5.25 7.5c-.41 0-.806.055-1.184.157A3 3 0 0 1 6.75 6h10.5a3 3 0 0 1 2.683 1.657A4.505 4.505 0 0 0 18.75 7.5H5.25Z" />
                      </svg>
                      <span>{{ 'templates.index.show_all' | t }}</span>
                  </a>
                  <button @click="listExpanded = !listExpanded" class="p-3 bg-gray-50 text-gray-400 rounded-lg hover:bg-gray-100 hover:text-gray-600 transition duration-150" title="展开/收起">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-5 h-5 w-5 transform transition-transform duration-200" :class="{ 'rotate-180': !listExpanded }">
                      <path fill-rule="evenodd" d="M11.47 7.72a.75.75 0 0 1 1.06 0l7.5 7.5a.75.75 0 1 1-1.06 1.06L12 9.31l-6.97 6.97a.75.75 0 0 1-1.06-1.06l7.5-7.5z" clip-rule="evenodd" />
                    </svg>
                  </button>
                </div>

                <div x-show="listExpanded" 
                     x-transition:enter="transition ease-out duration-200"
                     x-transition:enter-start="opacity-0 transform -translate-y-2"
                     x-transition:enter-end="opacity-100 transform translate-y-0"
                     x-transition:leave="transition ease-in duration-150"
                     x-transition:leave-start="opacity-100 transform translate-y-0"
                     x-transition:leave-end="opacity-0 transform -translate-y-2"
                     class="space-y-1">
                  {% for channel in channels %}
                    {%  assign ch =  channel.children_in_list | first %}
                    {% if ch.template_name == 'channel' %}
                      <div x-data="{ open: false }" class="group">
                          <a @click.prevent="open = !open" href="#"
                              class="flex items-center justify-between px-4 py-1 text-gray-700 hover:bg-gray-100 rounded-lg transition duration-150 cursor-pointer">
                              <span class="flex items-center space-x-2">
                                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-5 h-5 w-5">
                                    <path d="M19.906 9c.382 0 .749.057 1.094.162V9a3 3 0 0 0-3-3h-3.879a.75.75 0 0 1-.53-.22L11.47 3.66A2.25 2.25 0 0 0 9.879 3H6a3 3 0 0 0-3 3v3.162A3.756 3.756 0 0 1 4.094 9h15.812ZM4.094 10.5a2.25 2.25 0 0 0-2.227 2.568l.857 6A2.25 2.25 0 0 0 4.951 21H19.05a2.25 2.25 0 0 0 2.227-1.932l.857-6a2.25 2.25 0 0 0-2.227-2.568H4.094Z" />
                                  </svg>
                                  <span class="whitespace-nowrap overflow-hidden">{{ channel.link_text }}</span>
                              </span>
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-5 h-5 w-5 text-xs text-gray-400 transform transition-transform duration-200" :class="{ 'rotate-180': open }">
                                <path fill-rule="evenodd" d="M12.53 16.28a.75.75 0 0 1-1.06 0l-7.5-7.5a.75.75 0 0 1 1.06-1.06L12 14.69l6.97-6.97a.75.75 0 1 1 1.06 1.06l-7.5 7.5Z" clip-rule="evenodd" />
                              </svg>
                          </a>
                          <div x-show="open"
                                x-transition:enter="transition ease-out duration-200"
                                x-transition:enter-start="opacity-0 transform -translate-y-2"
                                x-transition:enter-end="opacity-100 transform translate-y-0"
                                x-transition:leave="transition ease-in duration-150"
                                x-transition:leave-start="opacity-100 transform translate-y-0"
                                x-transition:leave-end="opacity-0 transform -translate-y-2"
                                class="ml-6 pt-1 space-y-1 text-sm text-gray-600">
                              {% for item in channel.children_in_list %}
                                {% if item.template_name == 'channel' %}
                                  <a href="{{ item.path }}" class="block px-3 py-2 hover:text-primary rounded-md">{{ item.link_text }}</a>
                                {% endif %}
                              {% endfor %}
                          </div>
                      </div>
                    {% else %}
                      <a href="{{ channel.path }}" class="flex items-center justify-start space-x-2 px-4 py-1 text-gray-700 hover:bg-gray-100 rounded-lg transition duration-150">
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-5 h-5 w-5">
                            <path d="M19.906 9c.382 0 .749.057 1.094.162V9a3 3 0 0 0-3-3h-3.879a.75.75 0 0 1-.53-.22L11.47 3.66A2.25 2.25 0 0 0 9.879 3H6a3 3 0 0 0-3 3v3.162A3.756 3.756 0 0 1 4.094 9h15.812ZM4.094 10.5a2.25 2.25 0 0 0-2.227 2.568l.857 6A2.25 2.25 0 0 0 4.951 21H19.05a2.25 2.25 0 0 0 2.227-1.932l.857-6a2.25 2.25 0 0 0-2.227-2.568H4.094Z" />
                          </svg>
                          <span class="whitespace-nowrap overflow-hidden text-ellipsis">{{ channel.link_text }}</span>
                      </a>
                    {% endif %}
                  {% endfor %}
                </div>
              </nav>
          </div>
          <!-- 显示版本标签-->
          {% render 'section/version_tags', sorted_versions: sorted_versions %}
          <!-- 显示标签云-->
          {% render 'section/tag_cloud' %}
      </div>

      <div class="md:w-3/4">
        {% paginate_tag pages, per: 32 %}
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {% for item in pages %}
              {% render 'section/page_card', page: item %}
            {% endfor %}
              
          </div>

          <div class="flex justify-center mt-8">
            {% render 'paginate', paginate: paginate %}
          </div>
        {% endpaginate_tag %}
      </div>
  </div>
</main>

{% schema %}
  {
    "name": "t:schema.templates.index.name",
    "description": "t:schema.templates.index.description",
    "thumb_url": "images/schema/index.webp",
    "preview_image_urls": [
      "images/schema/index.webp"
    ],
    "sub_page_templates": ["channel"],
    "settings": [
      {
        "id": "hero_html",
        "type": "html",
        "label": "t:schema.templates.index.settings.hero_html.label"
      }
    ]
  }
{% endschema %}
