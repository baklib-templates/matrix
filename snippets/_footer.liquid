{% assign dark_logo = site.settings.dark_logo_url %}
{% assign icp_beian = site.settings.icp_beian | presence %}
{% assign footer_bg = site.settings.footer_bg_color | presence %}
{% unless footer_bg %}{% assign footer_bg = '#0b1220' %}{% endunless %}
{% assign footer_text = site.settings.footer_text_color | presence %}
{% unless footer_text %}{% assign footer_text = '#cbd5e1' %}{% endunless %}

<!-- Site footer -->
<footer class="relative" style="background-color: {{ footer_bg }}; color: {{ footer_text }};">
  <div class="container mx-auto py-10 px-4 sm:px-6 lg:px-8">
    {% assign footer_nav_links = site.settings.footer_nav_links | presence %}
    {% if footer_nav_links %}
      <nav class="mb-8 prose max-w-none prose-a:no-underline prose-a:text-[color:var(--matrix-primary)]">
        {{ footer_nav_links }}
      </nav>
    {% endif %}

    <div class="text-center">
      <p class="mb-2">
        {% if site.settings.footer_description != blank %}
          {{ site.settings.footer_description }}
        {% else %}
          {{ 'snippets.footer.default_description' | t }}
        {% endif %}
      </p>
      <p class="text-sm mb-4">
        &copy; {{ now | date: '%Y' }} {{ site.settings.copyright }}. All rights reserved.
        {% if icp_beian %}
          <a href="https://beian.miit.gov.cn/" target="_blank" class="underline underline-offset-4 opacity-90 hover:opacity-100">{{ icp_beian }}</a>
        {% endif %}
      </p>
      <p class="text-xs opacity-70">
        {{ 'snippets.footer.powered_by_prefix' | t }}
        <a href="https://www.baklib.com" target="_blank">
          <span class="font-semibold text-[color:var(--matrix-primary)]">Baklib</span>
        </a>
        {{ 'snippets.footer.powered_by_suffix' | t }}
      </p>
    </div>
  </div>
</footer>