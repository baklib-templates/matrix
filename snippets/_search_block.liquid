{% form_tag 'search', data-turbo-frame: 'frame--search-results', data-turbo-action: 'advance' %}
  <div class="relative text-gray-400 rounded-full group focus-within:text-gray-900 hover:text-gray-500">
    <button type="submit" class="flex absolute inset-y-0 right-0 items-center pr-4 pl-4">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
      </svg>
    </button>
    <input type="text" autofocus name="{{form.keywords_field_name}}" value="{{ search.keywords | truncate: 10 | escape }}" placeholder="{{ search_placeholder }}" class="block pr-12 pl-6 w-full h-8 bg-primary/10 dark:bg-gray-800 text-gray-900 dark:text-gray-100 placeholder:text-gray-400 dark:placeholder:text-gray-500
    rounded-full transition duration-300 ease-in-out border-transparent focus:border-primary focus:ring-4 focus:ring-primary/10 sm:text-md outline-none">
  </div>
{% endform_tag %}
