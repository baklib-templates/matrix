{% assign cta_label = page.settings.cta_label | presence %}
{% unless cta_label %}{% assign cta_label = '咨询/购买' %}{% endunless %}
{% assign cta_url = page.settings.cta_url | presence %}
{% unless cta_url %}{% assign cta_url = page.settings.original_url | presence %}{% endunless %}

{% assign specs_lines = page.settings.specs_json | presence %}
{% assign inventory = page.settings.inventory_status | presence %}

{% render 'matrix/page/_base_sections', page: page %}

<section class="mt-8 grid gap-4 md:grid-cols-3">
  <div class="md:col-span-2 space-y-4">
    <div class="glass-card rounded-2xl p-5">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100">参数对比表</h2>
      {% if specs_lines %}
        <div class="mt-4 overflow-x-auto">
          <table class="table w-full">
            <thead>
              <tr>
                <th>参数</th>
                <th>值</th>
              </tr>
            </thead>
            <tbody>
              {% assign specs = specs_lines | reg_split: "/\\n/" %}
              {% for row in specs %}
                {% assign kv = row | reg_split: "/:/" %}
                {% assign k = kv[0] | strip %}
                {% assign v = kv[1] | strip %}
                {% if k != blank and v != blank %}
                  <tr>
                    <td class="font-medium">{{ k }}</td>
                    <td class="opacity-80">{{ v }}</td>
                  </tr>
                {% endif %}
              {% endfor %}
            </tbody>
          </table>
        </div>
      {% else %}
        <p class="mt-2 text-sm opacity-70">在页面设置里填写 `specs_json`（每行：`Key: Value`）。</p>
      {% endif %}
    </div>
  </div>

  <aside class="md:col-span-1">
    <div class="glass-card rounded-2xl p-5 sticky top-24">
      <h3 class="font-semibold text-gray-900 dark:text-gray-100">库存状态</h3>
      {% if inventory %}
        <div class="mt-2 text-sm">
          <span class="px-2 py-1 rounded-full bg-gray-500/10">{{ inventory }}</span>
        </div>
      {% else %}
        <p class="mt-2 text-sm opacity-70">可在页面设置填写 `inventory_status`。</p>
      {% endif %}

      <div class="mt-5">
        {% if cta_url %}
          <a href="{{ cta_url }}" class="block text-center px-4 py-2 rounded-full bg-[var(--matrix-primary)] text-white hover:opacity-95">
            {{ cta_label }}
          </a>
        {% else %}
          <button type="button" class="w-full px-4 py-2 rounded-full border border-gray-200 dark:border-gray-700" @click="$store.matrixModal.open('product-cta')">
            {{ cta_label }}
          </button>
        {% endif %}
      </div>
    </div>
  </aside>
</section>

