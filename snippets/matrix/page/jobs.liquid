{% assign cta_label = page.settings.cta_label | presence %}
{% unless cta_label %}{% assign cta_label = '快速应聘' %}{% endunless %}
{% assign cta_url = page.settings.cta_url | presence %}
{% unless cta_url %}{% assign cta_url = page.path | append: '#apply' %}{% endunless %}

<div x-data="{ showApply: false }">
  {% render 'matrix/page/_base_sections', page: page %}

  <section class="mt-8 grid gap-4 md:grid-cols-3">
    <div class="md:col-span-2">
      <div class="glass-card rounded-2xl p-5">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100">职位信息</h2>
        <dl class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
          {% if page.settings.salary_range | presence %}
            <div>
              <dt class="opacity-70">薪资</dt>
              <dd class="mt-1 font-semibold text-[var(--matrix-primary)]">{{ page.settings.salary_range }}</dd>
            </div>
          {% endif %}
          {% if page.settings.location | presence %}
            <div>
              <dt class="opacity-70">地点</dt>
              <dd class="mt-1">{{ page.settings.location }}</dd>
            </div>
          {% endif %}
        </dl>
      </div>

      <div id="apply" class="mt-6 glass-card rounded-2xl p-5">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100">投递简历</h2>
        <p class="mt-1 text-sm text-gray-600 dark:text-gray-300">支持附件上传或粘贴链接，提交后保持在当前页面。</p>

        <div class="mt-4">
          <button
            type="button"
            class="px-4 py-2 rounded-full bg-[var(--matrix-primary)] text-white hover:opacity-95"
            @click="showApply = true"
          >打开应聘表单</button>
        </div>
      </div>
    </div>

    <aside class="md:col-span-1">
      <div class="glass-card rounded-2xl p-5 sticky top-24">
        <h3 class="font-semibold text-gray-900 dark:text-gray-100">快速应聘</h3>
        <p class="mt-1 text-sm opacity-70">1 分钟完成投递。</p>
        <div class="mt-4">
          <button
            type="button"
            class="w-full px-4 py-2 rounded-full bg-white text-gray-900 hover:bg-white/90 border border-white/40"
            @click="showApply = true"
          >{{ cta_label }}</button>
        </div>
      </div>
    </aside>
  </section>

  <template x-teleport="body">
    <div
      x-show="showApply"
      x-cloak
      class="fixed inset-0 z-[1000] flex items-center justify-center p-4"
      aria-modal="true"
      role="dialog"
    >
      <div class="absolute inset-0 bg-black/50" @click="showApply = false"></div>
      <div
        class="relative w-full max-w-xl glass-card rounded-2xl p-6 bg-white dark:bg-gray-900"
        x-transition:enter="transition ease-out duration-200"
        x-transition:enter-start="opacity-0 translate-y-3"
        x-transition:enter-end="opacity-100 translate-y-0"
        x-transition:leave="transition ease-in duration-150"
        x-transition:leave-start="opacity-100 translate-y-0"
        x-transition:leave-end="opacity-0 translate-y-3"
      >
        <div class="flex items-center justify-between gap-4">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100">应聘：{{ page.link_text }}</h3>
          <button type="button" class="opacity-70 hover:opacity-100" @click="showApply = false">
            <i class="ri-close-line text-2xl"></i>
          </button>
        </div>

        <form class="mt-4 space-y-3">
          <label class="block">
            <span class="text-sm opacity-70">姓名</span>
            <input class="mt-1 w-full rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 px-3 py-2" type="text" name="name" required>
          </label>
          <label class="block">
            <span class="text-sm opacity-70">邮箱/电话</span>
            <input class="mt-1 w-full rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 px-3 py-2" type="text" name="contact" required>
          </label>
          <label class="block">
            <span class="text-sm opacity-70">简历链接</span>
            <input class="mt-1 w-full rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 px-3 py-2" type="url" name="resume_url" placeholder="https://...">
          </label>
          <label class="block">
            <span class="text-sm opacity-70">备注</span>
            <textarea class="mt-1 w-full rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 px-3 py-2" rows="4" name="note"></textarea>
          </label>

          <div class="pt-2 flex items-center justify-end gap-2">
            <button type="button" class="px-4 py-2 rounded-full border border-gray-200 dark:border-gray-700" @click="showApply = false">取消</button>
            <button type="submit" class="px-4 py-2 rounded-full bg-[var(--matrix-primary)] text-white hover:opacity-95">提交</button>
          </div>
        </form>
      </div>
    </div>
  </template>
</div>

