<header class="mb-6">
  <h1 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-gray-100">{{ page.link_text }}</h1>
  {% if page.settings.description | presence %}
    <p class="mt-2 text-gray-600 dark:text-gray-300">{{ page.settings.description }}</p>
  {% endif %}
</header>

<article class="prose max-w-none dark:prose-invert">
  {% render 'page', page: page %}
</article>

