<div class="matrix-list space-y-3" data-matrix-filter-container>
  {% for item in items %}
    {% assign tags_csv = item.settings.tags | join: ',' %}
    {% assign salary = item.settings.salary_range | presence %}
    {% assign location = item.settings.location | presence %}
    {% assign published = item.published_at | date: "%Y-%m-%d" %}

    <article
      class="matrix-card glass-card rounded-2xl p-5 hover:translate-y-[-1px]"
      data-matrix-item
      data-tags="{{ tags_csv | escape_once }}"
      data-location="{{ location | escape_once }}"
      data-salary="{{ salary | escape_once }}"
    >
      <a href="{{ item.path }}" class="block">
        <div class="flex items-start justify-between gap-4">
          <div class="min-w-0">
            <h3 class="text-base font-semibold text-gray-900 dark:text-gray-100 truncate">
              {{ item.link_text }}
            </h3>
            {% if item.settings.description | presence %}
              <p class="mt-1 text-sm text-gray-500 dark:text-gray-300 line-clamp-2">
                {{ item.settings.description }}
              </p>
            {% endif %}
          </div>
          <div class="shrink-0 text-right">
            {% if salary %}
              <div class="text-sm font-semibold text-[var(--matrix-primary)]">{{ salary }}</div>
            {% endif %}
            {% if location %}
              <div class="text-xs opacity-70 mt-1">{{ location }}</div>
            {% endif %}
            <div class="text-[11px] opacity-60 mt-1">{{ published }}</div>
          </div>
        </div>
      </a>
    </article>
  {% endfor %}
</div>

