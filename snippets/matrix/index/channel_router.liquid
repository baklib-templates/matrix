{% assign matrix_active_mode = site.settings.active_mode | presence %}
{% unless matrix_active_mode %}{% assign matrix_active_mode = 'products' %}{% endunless %}

<div class="mb-4">
  {% render 'breadcrumb', breadcrumb: page.breadcrumb %}
</div>

<div class="md:flex md:space-x-6">
  <aside class="md:w-1/4 mb-6 md:mb-0">
    <div class="glass-card p-6 rounded-2xl sticky top-20">
      <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-2">{{ page.link_text }}</h2>
      {% if page.settings.description | presence %}
        <div class="mb-5 text-sm text-gray-500 dark:text-gray-300 line-clamp-4">
          {{ page.settings.description }}
        </div>
      {% endif %}

      <div class="relative mb-5">
        {% render 'search_block' %}
      </div>

      {% render 'matrix/index/sidebar_filters' %}
    </div>
  </aside>

  <section class="md:w-3/4">
    {% paginate_tag pages, per: 24 %}
      {% case matrix_active_mode %}
        {% when 'jobs' %}
          {% render 'matrix/index/list', items: pages %}
        {% when 'events' %}
          {% render 'matrix/index/timeline', items: pages %}
        {% when 'podcasts' %}
          {% render 'matrix/index/audio_list', items: pages %}
        {% else %}
          {% render 'matrix/index/grid', items: pages, mode: matrix_active_mode %}
      {% endcase %}

      <div class="flex justify-center mt-8">
        {% render 'paginate', paginate: paginate %}
      </div>
    {% endpaginate_tag %}
  </section>
</div>

