<div class="matrix-timeline space-y-4" data-matrix-filter-container>
  {% for item in items %}
    {% assign tags_csv = item.settings.tags | join: ',' %}
    {% assign start_at = item.settings.event_start_at | presence %}
    {% assign end_at = item.settings.event_end_at | presence %}
    {% assign location = item.settings.location | presence %}

    {% assign status = 'upcoming' %}
    {% if end_at and now > end_at %}{% assign status = 'ended' %}{% endif %}

    <article
      class="matrix-card glass-card rounded-2xl p-5"
      data-matrix-item
      data-tags="{{ tags_csv | escape_once }}"
      data-date="{{ start_at | escape_once }}"
      data-location="{{ location | escape_once }}"
    >
      <a href="{{ item.path }}" class="block">
        <div class="flex items-start gap-4">
          <div class="shrink-0">
            <div class="w-14 h-14 rounded-2xl flex items-center justify-center bg-[color-mix(in_oklab,var(--matrix-primary)_12%,transparent)] text-[var(--matrix-primary)]">
              <i class="ri-calendar-event-line text-2xl"></i>
            </div>
          </div>
          <div class="min-w-0 flex-1">
            <div class="flex items-center gap-2 flex-wrap">
              <h3 class="text-base font-semibold text-gray-900 dark:text-gray-100">
                {{ item.link_text }}
              </h3>
              {% if status == 'upcoming' %}
                <span class="text-[11px] px-2 py-0.5 rounded-full bg-emerald-500/10 text-emerald-700 dark:text-emerald-300">即将开始</span>
              {% else %}
                <span class="text-[11px] px-2 py-0.5 rounded-full bg-gray-500/10 text-gray-700 dark:text-gray-300">已结束</span>
              {% endif %}
            </div>

            <div class="mt-1 text-sm text-gray-500 dark:text-gray-300 flex flex-wrap gap-x-4 gap-y-1">
              {% if start_at %}
                <span class="inline-flex items-center gap-1">
                  <i class="ri-time-line"></i>
                  <span>{{ start_at }}</span>
                </span>
              {% endif %}
              {% if location %}
                <span class="inline-flex items-center gap-1">
                  <i class="ri-map-pin-line"></i>
                  <span>{{ location }}</span>
                </span>
              {% endif %}
            </div>

            {% if item.settings.description | presence %}
              <p class="mt-2 text-sm text-gray-500 dark:text-gray-300 line-clamp-2">
                {{ item.settings.description }}
              </p>
            {% endif %}
          </div>
        </div>
      </a>
    </article>
  {% endfor %}
</div>

