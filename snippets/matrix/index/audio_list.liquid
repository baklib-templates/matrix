<div class="matrix-audio-list space-y-3" data-matrix-filter-container>
  {% for item in items %}
    {% assign tags_csv = item.settings.tags | join: ',' %}
    {% assign duration = item.settings.audio_duration | presence %}
    {% assign audio_url = item.settings.audio_url | presence %}

    <article
      class="matrix-card glass-card rounded-2xl p-5"
      data-matrix-item
      data-tags="{{ tags_csv | escape_once }}"
      data-duration="{{ duration | escape_once }}"
    >
      <div class="flex items-start gap-4">
        <div class="shrink-0">
          <div class="w-14 h-14 rounded-2xl flex items-center justify-center bg-[color-mix(in_oklab,var(--matrix-primary)_12%,transparent)] text-[var(--matrix-primary)]">
            <i class="ri-headphone-line text-2xl"></i>
          </div>
        </div>
        <div class="min-w-0 flex-1">
          <a href="{{ item.path }}" class="block">
            <h3 class="text-base font-semibold text-gray-900 dark:text-gray-100 truncate">{{ item.link_text }}</h3>
            {% if item.settings.description | presence %}
              <p class="mt-1 text-sm text-gray-500 dark:text-gray-300 line-clamp-2">{{ item.settings.description }}</p>
            {% endif %}
          </a>

          <div class="mt-3 flex items-center gap-3">
            {% if audio_url %}
              <button
                type="button"
                class="inline-flex items-center gap-2 px-3 py-2 rounded-full bg-[var(--matrix-primary)] text-white text-sm hover:opacity-95"
                @click="$store.matrixPlayer.play('{{ audio_url | escape_once }}','{{ item.link_text | escape_once }}')"
              >
                <i class="ri-play-line"></i>
                播放
              </button>
            {% endif %}
            {% if duration %}
              <span class="text-xs opacity-70">{{ duration }}</span>
            {% endif %}
            <div class="flex-1 h-2 rounded-full bg-gray-200/70 dark:bg-gray-700/70 overflow-hidden">
              <div class="h-full w-1/3 bg-[color-mix(in_oklab,var(--matrix-primary)_45%,white)]"></div>
            </div>
          </div>
        </div>
      </div>
    </article>
  {% endfor %}
</div>

