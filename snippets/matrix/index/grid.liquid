{% assign matrix_mode = mode | presence %}
{% unless matrix_mode %}{% assign matrix_mode = 'products' %}{% endunless %}

{% comment %}
  Grid view:
  - products: 1:1
  - videos: 16:9
  - partners: logo-first
{% endcomment %}

{% assign card_ratio_class = 'aspect-square' %}
{% if matrix_mode == 'videos' %}{% assign card_ratio_class = 'aspect-video' %}{% endif %}

<div class="matrix-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" data-matrix-filter-container>
  {% for item in items %}
    {% assign tags_csv = item.settings.tags | join: ',' %}
    <article
      class="matrix-card glass-card rounded-2xl overflow-hidden group"
      data-matrix-item
      data-tags="{{ tags_csv | escape_once }}"
    >
      <a href="{{ item.path }}" class="block">
        <div class="relative {{ card_ratio_class }} bg-gray-100 dark:bg-gray-800 overflow-hidden">
          {% if item.settings.logo or item.settings.logo_url %}
            {% assign cover = item.settings.logo | presence %}
            {% unless cover %}{% assign cover = item.settings.logo_url | presence %}{% endunless %}
          {% elsif item.settings.icon or item.settings.icon_url %}
            {% assign cover = item.settings.icon | presence %}
            {% unless cover %}{% assign cover = item.settings.icon_url | presence %}{% endunless %}
          {% endif %}

          {% if cover %}
            <img src="{{ cover }}" alt="{{ item.link_text }}" class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-300">
          {% else %}
            <div class="w-full h-full flex items-center justify-center text-sm text-gray-500">
              {{ item.link_text }}
            </div>
          {% endif %}

          {% if matrix_mode == 'videos' %}
            <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-black/40 flex items-center justify-center">
              <span class="inline-flex items-center gap-2 px-3 py-2 rounded-full bg-white/90 text-gray-900 text-sm">
                <i class="ri-play-circle-line text-lg"></i>
                预览
              </span>
            </div>
          {% endif %}
        </div>

        <div class="p-5">
          <h3 class="text-base font-semibold text-gray-900 dark:text-gray-100 line-clamp-2">
            {{ item.link_text }}
          </h3>
          {% if item.settings.description | presence %}
            <p class="mt-2 text-sm text-gray-500 dark:text-gray-300 line-clamp-2">
              {{ item.settings.description }}
            </p>
          {% endif %}

          {% if tags_csv | presence %}
            <div class="mt-4 flex flex-wrap gap-2">
              {% for t in item.settings.tags | limit: 3 %}
                <span class="px-2 py-0.5 text-[11px] rounded-full border border-gray-200 dark:border-gray-700 text-gray-600 dark:text-gray-300">
                  #{{ t }}
                </span>
              {% endfor %}
            </div>
          {% endif %}
        </div>
      </a>
    </article>
  {% endfor %}
</div>

