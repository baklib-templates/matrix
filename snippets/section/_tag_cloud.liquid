{% assign is_compact = is_compact | default: false %}

<div class="{% unless is_compact %}glass-card p-6 rounded-2xl mt-6{% endunless %}">
  <h3 class="text-sm font-bold text-gray-700 mb-3">{{ 'templates.index.tag_cloud_title' | t: '标签云' }}</h3>
  <div class="flex flex-wrap gap-2">
    {% for tag in site.tags %}
      <a
        href="{{ tag.path }}"
        class="inline-block px-3 py-1 text-xs font-medium rounded-full border border-gray-200 text-gray-600 hover:border-primary hover:text-primary hover:bg-primary/5 transition-all duration-200"
        title="{{ tag.name }} ({{ tag.pages_count | default: 0 }})"
      >
        {{ tag.name }}
        {% if tag.pages_count > 0 %}
          <span class="ml-1 text-gray-400 text-[10px]">({{ tag.pages_count }})</span>
        {% endif %}
      </a>
    {% endfor %}
    {% if site.tags.size == 0 %}
      <p class="text-xs text-gray-400">{{ 'templates.index.no_tags' | t: '暂无标签' }}</p>
    {% endif %}
  </div>
</div>
