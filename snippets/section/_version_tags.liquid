
{% query all_pages_for_versions from site.pages %}
  {
    "where": {
      "template_name_eq": "page"
    },
    "order_by": "-published_at"
  }
{% endquery %}
{% comment %} 去重 page.settings.version（Baklib Liquid：拼接 token 后 split 再 sort）{% endcomment %}
{% assign v_acc = "::::" %}
{% for p in all_pages_for_versions %}
  {% assign v = p.settings.version | default: "" | strip %}
  {% if v != "" %}
    {% assign _tok = "::::" | append: v | append: "::::" %}
    {% unless v_acc contains _tok %}
      {% assign v_acc = v_acc | append: v | append: "::::" %}
    {% endunless %}
  {% endif %}
{% endfor %}
{% assign _raw_versions = v_acc | remove_first: "::::" | split: "::::" %}
{% assign sorted_versions = _raw_versions | compact | sort %}

{% assign is_compact = is_compact | default: false %}

<div class="{% unless is_compact %}glass-card p-6 rounded-2xl mt-6{% endunless %}">
  <h3 class="text-sm font-bold text-gray-700 mb-3">{{ 'templates.index.version_tags_title' | t }}</h3>
  <div class="flex flex-wrap gap-2">
    {% for v in sorted_versions %}
      {% if v != blank %}
        {% capture search_version_url -%}
          {{ site.root_path }}/s/news?version={{ v | url_encode }}
        {%- endcapture %}
        <a
          href="{{ search_version_url | strip }}"
          class="inline-block px-3 py-1 text-xs font-medium rounded-full border border-gray-200 text-gray-800 hover:border-primary hover:text-primary transition-all duration-200"
        >{{ v | escape_once }}</a>
      {% endif %}
    {% endfor %}
  </div>
</div>
