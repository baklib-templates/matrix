{% assign pages = site.pages['/'].pages_in_list | order_by: '-created_at' %}

{% if params.version != blank %}
  {% query pages from site.pages %}
      {
          "where": {
              "template_name_eq": "page",
              "settings.version_eq": params.version
          },
          "order_by": ["-created_at"]
      }
  {% endquery %}
{% endif %}

<main class="relative p-4 py-12 bg-white dark:bg-gray-900 main-gradient-bg"  x-data="{ showFilters: false }">

  {% form_tag 'search', data-turbo-frame: 'frame--search-results', data-turbo-action: 'advance' %}
    <div class="relative mx-auto w-full md:max-w-[70%] flex items-center text-gray-400 rounded-full group focus-within:text-gray-900 shadow-sm transition-all focus-within:shadow-md search-form-gradient">
      <!-- Filter Button (Left) -->
      <div class="flex items-center pl-2 border-r border-gray-100 dark:border-gray-700">
        <button type="button" @click="showFilters = !showFilters" :class="{ 'text-primary': showFilters }" class="flex items-center px-4 py-2 text-gray-400 hover:text-primary transition-colors group/filter">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
          </svg>
          <span class="ml-1 text-sm hidden lg:inline">{{ 'templates.search.filter_btn' | t: '筛选' }}</span>
        </button>
      </div>

      <input type="text" autofocus name="{{form.keywords_field_name}}" value="{{ search.keywords | truncate: 10 | escape }}" placeholder="{{ search_placeholder }}" class="flex-1 px-4 h-12 bg-transparent text-gray-900 dark:text-gray-100 placeholder:text-gray-400 dark:placeholder:text-gray-500 rounded-full border-none focus:ring-0 sm:text-md outline-none">
      
      <!-- Submit Button (Right) -->
      <button type="submit" class="flex items-center pr-4 pl-3 text-gray-400 hover:text-primary transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
      </button>
    </div>
  {% endform_tag %}
  <!-- Merged Filter Popup -->
  <div x-show="showFilters" 
        x-transition:enter="transition ease-out duration-200"
        x-transition:enter-start="opacity-0 translate-y-4 scale-95"
        x-transition:enter-end="opacity-100 translate-y-0 scale-100"
        x-transition:leave="transition ease-in duration-150"
        x-transition:leave-start="opacity-100 translate-y-0 scale-100"
        x-transition:leave-end="opacity-0 translate-y-4 scale-95"
        @click.away="showFilters = false" 
        class="absolute z-50 left-0 right-0 mx-auto w-full md:max-w-[70%] mt-3 p-6 bg-white dark:bg-gray-800 rounded-2xl shadow-2xl border border-gray-100 dark:border-gray-700 overflow-hidden"
        x-cloak>
    
    <div class="flex justify-between items-center mb-6 border-b pb-4 border-gray-100 dark:border-gray-700">
        <h4 class="text-gray-900 dark:text-gray-100 font-bold text-lg">{{ 'templates.search.filter_title' | t: '搜索筛选' }}</h4>
        <button @click="showFilters = false" class="text-gray-400 hover:text-gray-600 transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
    </div>

    <div class="space-y-8">
      <!-- Versions Section -->
      <section>
        {% render 'section/version_tags', is_compact: true %}
      </section>

      <!-- Divider -->
      <div class="h-px bg-gray-100 dark:bg-gray-700"></div>

      <!-- Tags Section -->
      <section>
        {% render 'section/tag_cloud', is_compact: true %}
      </section>
    </div>
  </div>

  <section class="container mx-auto mt-4 md:mt-12">
    {% paginate_tag pages, per: 32 %}
      <!-- Page List (Table View) -->
      {% render 'section/page_table', pages: pages %}

      <div class="flex justify-center mt-8">
        {% render 'paginate', paginate: paginate %}
      </div>
    {% endpaginate_tag %}
  </section>

</main>